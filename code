  <style>
    :root { --color: #941d57; --color-alpha: rgba(148,29,87,0.42); }

    *{ box-sizing:border-box; margin:0; padding:0; font-family:'Poppins',sans-serif; }
    html { font-size:62.5%; scroll-behavior:smooth; }
    body{ background-image:url("https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcT0ABbTi9K1somzA_6DCUky9punS24K3lwbMA&s"); background-size: cover; }
    .header{
      position:fixed; top:0; left:0; right:0; z-index:1000;
      display:flex; align-items:center; justify-content:space-between;
      padding:2rem 6%; background:var(--color-alpha);
      backdrop-filter: blur(4px);
      box-shadow:0 0.5rem 1rem rgba(0,0,0,0.07);
    }
    .logo{ font-size:2.4rem; font-weight:700; color:#fff; text-decoration:none; display:flex; align-items:center; gap:.8rem; }
    .logo .dot{ width:2.4rem; height:2.4rem; background:#fff; border-radius:50%; display:inline-block; }

    .navbar{ display:flex; gap:2rem; align-items:center; }
    .navbar a{ color:#fff; text-decoration:none; font-size:1.6rem; padding:.6rem 1rem; border-radius:.6rem; }
    .navbar a:hover{ background:rgba(0,0,0,0.08); color:#fff; }

    .icons{ display:flex; gap:1.2rem; align-items:center; color:#fff; }
    .btn{ display:inline-block; padding:.8rem 2.4rem; background:var(--color); color:#fff; font-size:1.6rem; border-radius:.6rem; cursor:pointer; text-decoration:none; }

    .hamburger{ display:none; flex-direction:column; cursor:pointer; gap:.4rem; }
    .hamburger .line{ width:28px; height:3px; background:#fff; border-radius:2px; }


    .slides-container{ max-width:1200px; margin:0 auto; padding:3rem; position:relative; }
    .slide{ display:none; gap:2rem; align-items:center; }
    .slide.active{ display:flex; }
    .slide .content{ flex:1; }
    .slide .content h1{ font-size:4.2rem; color: #0f0000; margin-bottom:1rem; }
    .slide .content p{ font-size:1.6rem; margin-bottom:1.6rem; color:#0f0000; }
    .slide .img{ flex:1; display:flex; justify-content:center; }
    .slide .img img{ width:100%; max-width:420px; border-radius:1rem; box-shadow:0 .6rem 1.2rem rgba(0,0,0,0.08); }

    .slide-controls{ position:absolute; top:50%; left:2rem; right:2rem; display:flex; justify-content:space-between; transform:translateY(-50%); gap:1rem; pointer-events:none; }
    .slide-controls button{ pointer-events:auto; height:4.6rem; width:4.6rem; border-radius:50%; border:0; background:var(--color); color:#fff; cursor:pointer; box-shadow:0 .5rem 1rem rgba(0,0,0,0.12); }

    .banner-container{ max-width:1200px; margin:3.2rem auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(28rem,1fr)); gap:1.2rem; padding:0 3rem; }
    .banner{ position:relative; height:20rem; border-radius:1rem; overflow:hidden; box-shadow:0 .6rem 1.2rem rgba(0,0,0,0.08); }
    .banner img{width:100%; height:100%; object-fit:cover; display:block; }
    .banner .content{ position:absolute; left:2rem; top:50%; transform:translateY(-50%); color:#fff; }

    .section{ padding:4rem 3rem; max-width:1200px; margin:0 auto; }
    .title{ display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; }
    .title h2{ font-size:2.4rem; color:#0f0000; }
    .products-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(22rem,1fr)); gap:1.2rem; }
    .product{ background:#fff; border-radius:.8rem; padding:1.2rem; text-align:center; box-shadow:0 .6rem 1.2rem rgba(0,0,0,0.06); }
    .product img{ width:100%; height:16rem; object-fit:cover; border-radius:.6rem; margin-bottom:1rem; }
    .product h3{ font-size:1.8rem; margin-bottom:.6rem; color:#222; }
    .price{ font-size:1.6rem; color:var(--color); font-weight:600; margin-bottom:1rem; }
    .add{ background:var(--color); color:#fff; padding:.6rem 1.2rem; border-radius:.6rem; cursor:pointer; display:inline-block; }

    .about{ display:flex; gap:2rem; align-items:center; flex-wrap:wrap; }
    .about .text{ flex:1; }
    .about .img{ flex:1; }
    .about img{ width:100%; border-radius:.8rem; }

    input[type="text"], input[type="email"], textarea{ width:100%; padding:1rem; margin-bottom:1rem; border-radius:.6rem; border:1px solid rgba(0,0,0,0.08); }
    .contact-form{ max-width:800px; margin-top:1.2rem; }

    .footer{ background:var(--color-alpha); padding:2.4rem 3rem; margin-top:3rem; color:#fff; text-align:center; }

    @media (max-width:900px){
      .navbar{ display:none; position:absolute; top:70px; left:0; right:0; flex-direction:column; gap:0; background:var(--color); padding:1.2rem; }
      .navbar.active{ display:flex; }
      .hamburger{ display:flex; }
      .slides-container{ padding:1.2rem; }
      .slide .content h1{ font-size:3.2rem; }
      .about{ flex-direction:column; }
    }
  </style>
</head>

